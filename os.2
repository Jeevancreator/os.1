File open, read, write, close
#include <fcntl.h>
#include <unistd.h>
#include <stdio.h>

int main() {
    int fd;
    char buffer[100];
    int n;
    fd = open("example.txt", O_CREAT | O_RDWR, 0644);
    if (fd < 0) {
        perror("open");
        return 1;
    }
    write(fd, "Hello UNIX I/O\n", 14);

    lseek(fd, 0, SEEK_SET);   // Move file pointer to beginning

    n = read(fd, buffer, sizeof(buffer) - 1);
    buffer[n] = '\0';

    write(1, buffer, n);     // Write to stdout
    close(fd);
    return 0;
}

Using lseek() (random file access)
#include <fcntl.h>
#include <unistd.h>
#include <stdio.h>

int main() {
    int fd = open("example.txt", O_RDONLY);
    char ch;

    lseek(fd, 6, SEEK_SET);  // Move to 7th byte
    read(fd, &ch, 1);

    write(1, &ch, 1);        // Output single character
    close(fd);
    return 0;
}










File information using stat()
#include <sys/stat.h>
#include <stdio.h>

int main() {
    struct stat info;

    if (stat("example.txt", &info) == 0) {
        printf("File size: %ld bytes\n", info.st_size);
        printf("Inode number: %ld\n", info.st_ino);
        printf("Permissions: %o\n", info.st_mode & 0777);
    } else {
        perror("stat");
    }
    return 0;
}










File locking using fcntl()

#include <fcntl.h>
#include <unistd.h>
#include <stdio.h>

int main() {
    int fd = open("example.txt", O_RDWR);
    struct flock lock;

    lock.l_type = F_WRLCK;     // Write lock
    lock.l_whence = SEEK_SET;
    lock.l_start = 0;
    lock.l_len = 0;           // Lock entire file

    fcntl(fd, F_SETLK, &lock);
    printf("File locked. Press Enter to unlock...\n");
    getchar();

    lock.l_type = F_UNLCK;
    fcntl(fd, F_SETLK, &lock);

    close(fd);
    return 0;
}
Directory handling using opendir() and readdir()
#include <dirent.h>
#include <stdio.h>

int main() {
    DIR *dir;
    struct dirent *entry;

    dir = opendir(".");
    if (dir == NULL) {
        perror("opendir");
        return 1;
    }

    while ((entry = readdir(dir)) != NULL) {
        printf("%s\n", entry->d_name);
    }

    closedir(dir);
    return 0;
}
